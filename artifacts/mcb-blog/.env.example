# Prisma Postgres connection string from prisma.io/postgres
# Format: prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_KEY
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_KEY_HERE"

# Full URL of your deployed app (no trailing slash)
NEXTAUTH_URL="https://your-app.vercel.app"

# Random secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"
